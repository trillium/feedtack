npx lint-staged

MAX_LINES=300
FAILED=0

# Check staged ts/tsx source files (exclude tests, configs, lock files)
for file in $(git diff --cached --name-only --diff-filter=ACM | grep -E '\.tsx?$' | grep -v '\.test\.' | grep -v '\.config\.' ); do
  if [ -f "$file" ]; then
    lines=$(wc -l < "$file")
    if [ "$lines" -gt "$MAX_LINES" ]; then
      echo "ERROR: $file has $lines lines (max $MAX_LINES)"
      FAILED=1
    fi
  fi
done

if [ "$FAILED" -eq 1 ]; then
  echo ""
  echo "Split large files before committing. Test files, configs, and lock files are exempt."
  exit 1
fi
